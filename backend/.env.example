# =============================================================================
# GutBot Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit real credentials to version control.
# See .env.example for field descriptions.
# =============================================================================

# ── 1. LLM BACKEND ────────────────────────────────────────────────────────────
LLM_BACKEND=bedrock

# ── 2. AWS BEDROCK ────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=mistral.mistral-7b-instruct-v0:2
BEDROCK_MAX_TOKENS=512
BEDROCK_TEMPERATURE=0.2

AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# ── 3. LLAMA SERVER (alternative backend) ─────────────────────────────────────
LLAMA_SERVER_URL=http://localhost:8000/chat
LLAMA_MODEL_NAME=qwen
LLAMA_MAX_TOKENS=512
LLAMA_TEMPERATURE=0.2

# ── 4. REQUEST SETTINGS ───────────────────────────────────────────────────────
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1

# ── 5. EMBEDDING MODEL ────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── 6. DEPLOYMENT ─────────────────────────────────────────────────────────────
# Set to "production" on EC2
FLASK_ENV=development

# Set to your EC2 public IP or domain when deploying, e.g.: 54.123.45.67
# Leave empty for local development
EC2_DOMAIN=
